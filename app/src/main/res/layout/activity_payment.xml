<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💳 SECURE CHECKOUT"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFD700"
            android:layout_marginBottom="30dp"/>

        <!-- SUMMARY CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="16dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvPaymentDrama"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Drama: --"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvPaymentSeat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selected Seat: --"
                    android:textColor="#BBBBBB"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#333333"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOTAL AMOUNT: ₹100.00"
                    android:textColor="#FFD700"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- DIRECT UPI PAYMENT BUTTON (As Fallback) -->
        <Button
            android:id="@+id/btnPayViaUPI"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="🚀 PAY VIA UPI APP (GPay/PhonePe)"
            android:textStyle="bold"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OR Scan QR Code with any App"
            android:textColor="#888888"
            android:textSize="14sp"
            android:layout_marginBottom="12dp"/>

        <ImageView
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:src="@drawable/upi_qr"
            android:background="@android:color/white"
            android:padding="10dp"
            android:layout_marginBottom="24dp"
            android:contentDescription="UPI QR Code"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter Payment Details Below"
            android:textColor="#888888"
            android:textSize="14sp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Confirm Amount Paid (₹100)"
            android:textColorHint="#666666"
            android:textColor="#FFFFFF"
            android:padding="16dp"
            android:background="@drawable/search_bg"
            android:inputType="number"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etTransactionId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter 12-digit Ref Number"
            android:textColorHint="#666666"
            android:textColor="#FFFFFF"
            android:padding="16dp"
            android:background="@drawable/search_bg"
            android:inputType="number"
            android:maxLength="12"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnPaymentDone"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="VERIFY &amp; BOOK TICKET"
            android:textStyle="bold"
            android:backgroundTint="#FFD700"
            android:textColor="#000000"
            android:textSize="18sp"/>

        <ProgressBar
            android:id="@+id/paymentProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginTop="16dp"
            android:indeterminateTint="#FFD700"/>

    </LinearLayout>
</ScrollView>
