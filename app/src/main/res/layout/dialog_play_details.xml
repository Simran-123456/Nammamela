<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="20dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tonight's Special Play"
            android:textColor="#FFD700"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/imgClose"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#FFFFFF" />
    </RelativeLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginTop="20dp"
        app:cardCornerRadius="16dp">

        <ImageView
            android:id="@+id/imgDialogPoster"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/poster3"
            android:scaleType="centerCrop" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvDialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Nann Aase Nataka"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvDialogVenue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🏛️ Venue: Shivamogga Town Hall"
        android:textColor="#FFD700"
        android:textSize="16sp"
        android:layout_marginTop="4dp"/>

    <TextView
        android:id="@+id/tvDialogLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🌍 Location: Shivamogga, Karnataka"
        android:textColor="#BBBBBB"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvDialogDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="🕒 Duration: 3 Hours 15 Mins"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginVertical="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Star Cast"
        android:textColor="#FFD700"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvCastList"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Actor, Comedian, Singer"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:lineSpacingExtra="4dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/btnBookNow"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="BOOK MY SEAT NOW"
        android:backgroundTint="#FFD700"
        android:textColor="#000000"
        android:textStyle="bold"
        android:textSize="18sp" />

</LinearLayout>
